<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net9.0</TargetFramework>
        <PackageId>EFCore.Migrations.AutoComments</PackageId>
        <Title>AutoComments</Title>
        <Version>9.0.5</Version>
        <Authors>AndreqGav</Authors>
        <Product>EFCore.Migrations.AutoComments</Product>
        <Description>Automatic addition of comments for entities based on XML documentation file.</Description>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <PackageTags>entity framework core; entity-framework-core; ef core; ef-core; autocomments; auto comments; auto-comments; comment; comments; ef comment;</PackageTags>
        <RepositoryUrl>https://github.com/AndreqGav/EFCore.Migrations.AutoComments</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <Copyright>Copyright (c) Андрей Гаврилов 2026</Copyright>
        <PackageReleaseNotes>Automatically add comments to columns and tables</PackageReleaseNotes>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.EntityFrameworkCore.Relational" Version="9.0.0"/>
    </ItemGroup>

</Project>
